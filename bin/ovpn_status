#!/bin/bash

#
# Get OpenVPN server status
#
if [ "$DEBUG" == "1" ]; then
  set -x
fi

set -e

if [ -z "${OPENVPN:-}" ]; then
  OPENVPN="$PWD"
fi

[ -r "$OPENVPN/ovpn_env.sh" ] && . "$OPENVPN/ovpn_env.sh"

if [ "${OVPN_LOG_APPEND:-0}" == "1" ]; then
  exec tail -F /tmp/openvpn-status.log /etc/openvpn/openvpn.log
else
  exec tail -F /tmp/openvpn-status.log
fi
